#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  install-host [options] <host> <target>

Examples:
  install-host kamo nixos@192.168.0.99
  install-host --no-install kamo nixos@192.168.0.99

Target requirements:
  - Booted into the official NixOS ISO
  - Network connected
  - Password set for the nixos user
  - SSH reachable, usually as nixos@<ip>

What this script does:
  - checks SSH connectivity
  - shows remote disk IDs for comparison with hosts/<host>/storage/disko.nix
  - writes hosts/<host>/generated/hardware-configuration.nix
  - writes hosts/<host>/generated/ssh_host_ed25519_key.pub
  - prepares /tmp/<host>/etc/ssh for nixos-anywhere --extra-files
  - runs agenix rekey
  - formats the repo
  - evaluates the host
  - optionally runs nixos-anywhere

Options:
  --no-install       Prepare generated files and rekey, but do not run nixos-anywhere
  --no-rekey         Do not run agenix rekey
  --no-format        Do not run nix fmt
  --force            Skip confirmation prompts except destructive install confirmation
  -h, --help         Show this help
USAGE
}

die() {
  echo "error: $*" >&2
  exit 1
}

info() {
  echo
  echo "==> $*"
}

warn() {
  echo "warning: $*" >&2
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing command: $1"
}

confirm() {
  local prompt="$1"
  local answer

  if [[ "$force" == "1" ]]; then
    echo "$prompt [auto-yes due to --force]"
    return 0
  fi

  read -r -p "$prompt [y/N] " answer
  case "$answer" in
    y|Y|yes|YES) ;;
    *) die "aborted" ;;
  esac
}

write_host_key_file() {
  local host="$1"
  local target="$2"
  local file="hosts/${host}/generated/ssh_host_ed25519_key.pub"

  mkdir -p "hosts/${host}/generated"

  ssh "$target" 'cat /etc/ssh/ssh_host_ed25519_key.pub' > "$file"

  echo "wrote: $file"
  echo "public key: $(cat "$file")"
}

prepare_extra_files() {
  local host="$1"
  local target="$2"
  local extra_dir="/tmp/${host}"

  rm -rf "$extra_dir"
  mkdir -p "$extra_dir/etc/ssh"

  ssh "$target" \
    'sudo tar -C /etc/ssh -cf - ssh_host_ed25519_key ssh_host_ed25519_key.pub' \
    | tar -C "$extra_dir/etc/ssh" -xf -

  chmod 600 "$extra_dir/etc/ssh/ssh_host_ed25519_key"
  chmod 644 "$extra_dir/etc/ssh/ssh_host_ed25519_key.pub"

  echo "$extra_dir"
}

show_disk_ids() {
  local target="$1"

  ssh "$target" 'ls -l /dev/disk/by-id/ | sed -n "1,200p"'
}

generate_hardware_config() {
  local host="$1"
  local target="$2"
  local file="hosts/${host}/generated/hardware-configuration.nix"

  mkdir -p "hosts/${host}/generated"

  if [[ -f "$file" ]]; then
    cp "$file" "${file}.bak"
    echo "backup: ${file}.bak"
  fi

  ssh "$target" 'nixos-generate-config --show-hardware-config' > "$file"

  echo "wrote: $file"
}

no_install=0
no_rekey=0
no_format=0
force=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --no-install)
      no_install=1
      shift
      ;;
    --no-rekey)
      no_rekey=1
      shift
      ;;
    --no-format)
      no_format=1
      shift
      ;;
    --force)
      force=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      die "unknown option: $1"
      ;;
    *)
      break
      ;;
  esac
done

host="${1:-}"
target="${2:-}"

[[ -n "$host" ]] || { usage; exit 1; }
[[ -n "$target" ]] || { usage; exit 1; }
[[ $# -le 2 ]] || die "disk argument was removed; edit hosts/${host}/storage/disko.nix instead"

[[ -f flake.nix ]] || die "run this script from the flake root"
[[ -d "hosts/$host" ]] || die "hosts/$host does not exist"
[[ -f "hosts/$host/storage/disko.nix" ]] || die "hosts/$host/storage/disko.nix does not exist"

require_cmd ssh
require_cmd tar
require_cmd nix
require_cmd chmod

if [[ "$no_rekey" != "1" ]]; then
  require_cmd agenix
fi

info "Install target"
echo "Host:   $host"
echo "Target: $target"

info "Checking flake host"
nix eval --raw ".#nixosConfigurations.${host}.config.networking.hostName" >/dev/null

info "Checking SSH connectivity"
ssh "$target" 'echo connected'

info "Remote disk IDs"
show_disk_ids "$target"
echo

info "Host disko configuration"
echo "Using: hosts/${host}/storage/disko.nix"
confirm "Continue using this disko configuration for ${host}?"

info "Generating hardware configuration"
generate_hardware_config "$host" "$target"

info "Reading ISO SSH host public key"
write_host_key_file "$host" "$target"

info "Preparing extra-files with ISO SSH host keys"
extra_dir="$(prepare_extra_files "$host" "$target")"
echo "prepared: $extra_dir"

if [[ "$no_rekey" != "1" ]]; then
  info "Rekeying agenix secrets"
  agenix rekey
else
  warn "skipping agenix rekey due to --no-rekey"
fi

if [[ "$no_format" != "1" ]]; then
  info "Formatting repository"
  nix fmt
else
  warn "skipping nix fmt due to --no-format"
fi

info "Evaluating host"
nix eval --raw ".#nixosConfigurations.${host}.config.system.build.toplevel.drvPath" >/dev/null

info "Summary"
echo "Host:       $host"
echo "Target:     $target"
echo "Disko:      hosts/${host}/storage/disko.nix"
echo "ExtraFiles: $extra_dir"
echo

echo "Generated or updated:"
echo "  hosts/${host}/generated/hardware-configuration.nix"
echo "  hosts/${host}/generated/ssh_host_ed25519_key.pub"
echo

if [[ "$no_install" == "1" ]]; then
  echo "--no-install was specified. Skipping nixos-anywhere."
  exit 0
fi

echo "This will install NixOS using hosts/${host}/storage/disko.nix and may destroy existing data."
echo
read -r -p "Type '${host}' to start nixos-anywhere: " typed
[[ "$typed" == "$host" ]] || die "host confirmation did not match"

info "Running nixos-anywhere"
nix run github:nix-community/nixos-anywhere -- \
  --flake ".#${host}" \
  --extra-files "$extra_dir" \
  "$target"
